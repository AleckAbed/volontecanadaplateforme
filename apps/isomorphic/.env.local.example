# =============================================================================
#  Volonté Canada Admin App — Configuration frontend
#
#  Copier ce fichier en .env.local et remplir les valeurs.
#  Ne JAMAIS committer .env.local (déjà dans .gitignore).
# =============================================================================

# URL de l'API Laravel (backend)
#  - Local  : http://localhost:8000/api
#  - Prod   : https://api.tondomaine.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# URL publique du frontend Next.js
#  - Local  : http://localhost:3001
#  - Prod   : https://app.tondomaine.com
NEXTAUTH_URL=http://localhost:3001

# Secret NextAuth — CRITIQUE pour la sécurité des sessions.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Ne JAMAIS réutiliser le même secret entre environnements.
NEXTAUTH_SECRET=

# Environnement Node.js
#  - development  : pour dev local
#  - production   : pour build/run prod
NODE_ENV=development

# Nom affiché de l'application
NEXT_PUBLIC_APP_NAME=Cabinet d'Immigration

# Adobe PDF Embed API — clé liée à un domaine spécifique.
# Obtenir une clé gratuite sur https://developer.adobe.com/document-services/apis/pdf-embed/
# ATTENTION : chaque clé est limitée à un domaine. La clé de localhost ne marchera
# pas sur app.tondomaine.com — il faut en générer une nouvelle pour la prod.
NEXT_PUBLIC_ADOBE_CLIENT_ID=

# OPTIONNEL : Google OAuth (si tu actives l'auth Google côté admin)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OPTIONNEL : Google Maps API (si fonctionnalité carte utilisée)
# NEXT_PUBLIC_GOOGLE_MAP_API_KEY=
